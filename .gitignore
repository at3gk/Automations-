# Secrets & local env — never commit these
.env
.env.*
*.env
secrets
secrets.*
*.secret
*.local
.credentials
credentials.json
token.json
*.pem
*.key

# inbox-pipeline — data/state lives in Drive, never in git (see inbox-pipeline/docs/DRIVE_LAYOUT.md)
inbox-pipeline/dist/*
!inbox-pipeline/dist/.gitkeep
inbox-pipeline/state/*
!inbox-pipeline/state/.gitkeep
ledger-*.json
inbox-state.json
*.financial.json
extracted/

# Python bytecode (generators / capweb)
__pycache__/
*.pyc

